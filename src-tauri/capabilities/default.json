{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-kill",
    "clipboard-manager:allow-write",
    "clipboard-manager:allow-read",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load"
  ]
}
